{
  "name": "qa-juice-shop",
  "version": "1.0.0",
  "description": "Playwright automation project for OWASP Juice Shop",
  "main": "index.js",
  "scripts": {
    "test": "playwright test --project=chromium",
    "test:ci": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:security": "playwright test tests/security",
    "test:smoke": "playwright test --grep @smoke",
    "test:auth": "playwright test --grep @auth",
    "test:search": "playwright test --grep @search",
    "test:basket": "playwright test --grep @basket",
    "test:chromium": "playwright test --project=chromium",
    "test:firefox": "playwright test --project=firefox",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:allure": "playwright test --reporter=line,allure-playwright",
    "allure:generate": "allure generate ./allure-results --clean -o ./allure-report",
    "allure:open": "allure open ./allure-report",
    "analyze": "tsx src/agents/analyzer/analyzeResults.ts",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down -v"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LenaChe-1234/qa-juice-shop.git"
  },
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.5.0",
    "allure-commandline": "^2.38.1",
    "allure-playwright": "^3.6.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
